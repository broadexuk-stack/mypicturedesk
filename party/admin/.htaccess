# admin/.htaccess — Whitelist only known admin entry points.

Options -Indexes

# Allow only these PHP files; deny everything else (including setup.php once deleted)
<FilesMatch "^(?!index\.php$|moderate\.php$|thumb\.php$|poll\.php$|download_gallery\.php$|setup\.php$|setpassword\.php$|parties\.php$|organizer_settings\.php$|qrcode\.php$|superadmin_settings\.php$)">
    Require all denied
</FilesMatch>
